{
	"name": "IvyShell",
	"type": "dark",
	"colors": {
		"focusBorder": "#d1c593",
		"foreground": "#f2eadd",
		"descriptionForeground": "#494a39",
		"errorForeground": "#b86161",
		"textLink.foreground": "#5a7a98",
		"textLink.activeForeground": "#d1c593",
		"textBlockQuote.background": "#171716",
		"textBlockQuote.border": "#3d3a38",
		"textCodeBlock.background": "#1c1b1a",
		"textPreformat.foreground": "#f2eadd",
		"textSeparator.foreground": "#494a39",
		"button.background": "#668e37",
		"button.foreground": "#171716",
		"checkbox.background": "#252423",
		"checkbox.border": "#171716",
		"dropdown.background": "#1c1b1a",
		"dropdown.border": "#171716",
		"input.background": "#1c1b1a",
		"input.border": "#3d3a38",
		"input.foreground": "#f2eadd",
		"badge.background": "#5a7a98",
		"progressBar.background": "#d1c593",
		"titleBar.activeBackground": "#171716",
		"titleBar.activeForeground": "#f2eadd",
		"activityBar.background": "#171716",
		"activityBar.foreground": "#d1c593",
		"activityBar.inactiveForeground": "#494a39",
		"sideBar.background": "#171716",
		"sideBar.foreground": "#c9c5a7",
		"sideBar.border": "#171716",
		"editor.background": "#1c1b1a",
		"editor.foreground": "#f2eadd",
		"editor.lineHighlightBackground": "#252423",
		"editorCursor.foreground": "#d1c593",
		"editorIndentGuide.background": "#252423",
		"editorIndentGuide.activeBackground": "#3d3a38",
		"editor.selectionBackground": "#d1c59344",
		"statusBar.background": "#171716",
		"statusBar.foreground": "#c9c5a7",
		"statusBar.border": "#171716",
		"editorGroupHeader.tabsBackground": "#171716",
		"tab.activeBackground": "#1c1b1a",
		"tab.activeForeground": "#f2eadd",
		"tab.inactiveBackground": "#171716",
		"tab.inactiveForeground": "#494a39",
		"tab.border": "#171716",
		"tab.activeBorderTop": "#d1c593",
		"list.hoverBackground": "#252423",
		"list.activeSelectionBackground": "#252423",
		"list.activeSelectionForeground": "#f2eadd"
	},
	"tokenColors": [
		{
			"scope": [
				"comment",
				"punctuation.definition.comment",
				"string.comment"
			],
			"settings": { "foreground": "#494a39" }
		},
		{
			"scope": [
				"constant",
				"entity.name.constant",
				"variable.other.constant",
				"variable.other.enummember",
				"variable.language"
			],
			"settings": { "foreground": "#5a7a98" }
		},
		{
			"scope": ["entity", "entity.name"],
			"settings": { "foreground": "#a06080" }
		},
		{
			"scope": "variable.parameter.function",
			"settings": { "foreground": "#f2eadd" }
		},
		{
			"scope": "entity.name.tag",
			"settings": { "foreground": "#668e37" }
		},
		{
			"scope": "keyword",
			"settings": { "foreground": "#b86161" }
		},
		{
			"scope": ["storage", "storage.type"],
			"settings": { "foreground": "#b86161" }
		},
		{
			"scope": [
				"storage.modifier.package",
				"storage.modifier.import",
				"storage.type.java"
			],
			"settings": { "foreground": "#f2eadd" }
		},
		{
			"scope": [
				"string",
				"punctuation.definition.string",
				"string punctuation.section.embedded source"
			],
			"settings": { "foreground": "#5a8a80" }
		},
		{
			"scope": ["support", "meta.property-name"],
			"settings": { "foreground": "#5a7a98" }
		},
		{
			"scope": "variable",
			"settings": { "foreground": "#c29f5e" }
		},
		{
			"scope": "variable.other",
			"settings": { "foreground": "#f2eadd" }
		},
		{
			"scope": [
				"invalid.broken",
				"invalid.deprecated",
				"invalid.illegal",
				"invalid.unimplemented"
			],
			"settings": { "fontStyle": "italic", "foreground": "#b86161" }
		},
		{
			"scope": "string variable",
			"settings": { "foreground": "#5a7a98" }
		},
		{
			"scope": ["source.regexp", "string.regexp"],
			"settings": { "foreground": "#5a8a80" }
		},
		{
			"scope": "markup.heading",
			"settings": { "fontStyle": "bold", "foreground": "#5a7a98" }
		},
		{
			"scope": "markup.quote",
			"settings": { "foreground": "#668e37" }
		},
		{
			"scope": "markup.italic",
			"settings": { "fontStyle": "italic", "foreground": "#f2eadd" }
		},
		{
			"scope": "markup.bold",
			"settings": { "fontStyle": "bold", "foreground": "#f2eadd" }
		},
		{
			"scope": "markup.inline.raw",
			"settings": { "foreground": "#5a7a98" }
		}
	],
	"semanticHighlighting": true
}
